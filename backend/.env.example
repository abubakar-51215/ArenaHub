# ArenaHub backend environment variables.
# Copy to .env and fill in real values. .env is gitignored.

# --- Core ---
ENVIRONMENT=dev                 # dev | staging | prod
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# --- Database (native PostgreSQL on Windows) ---
# Async driver (asyncpg) is used by the app.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arenahub

# --- Redis (Memurai on Windows, Redis-compatible) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
# Use a random secret of at least 32 bytes each (e.g. `openssl rand -hex 32`).
# Access tokens live 15 min, refresh tokens 7 days (rotated on every use).
JWT_SECRET=replace-with-a-32-byte-random-hex-secret-000000
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-random-hex-000000

# --- Cloud image storage (Cloudinary) ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Payment gateways ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
EASYPAISA_MERCHANT_ID=

# --- Email (OTP delivery; dev logs OTP to console instead) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# --- Push notifications (Firebase Cloud Messaging) ---
FCM_SERVER_KEY=
