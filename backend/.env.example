# ArenaHub backend environment variables.
# Copy to .env and fill in real values. .env is gitignored.

# --- Core ---
ENVIRONMENT=dev                 # dev | staging | prod
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# --- Database (native PostgreSQL on Windows) ---
# Async driver (asyncpg) is used by the app.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arenahub

# Tests never touch the database above — tests/conftest.py derives a
# dedicated "<db>_test" database from this URL automatically (create it once
# and run migrations against it, see backend/README.md "Running tests").
# Set TEST_DATABASE_URL here only if you want to point tests somewhere else.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arenahub_test

# --- Redis (Memurai on Windows, Redis-compatible) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
# Use a random secret of at least 32 bytes each (e.g. `openssl rand -hex 32`).
# Access tokens live 15 min, refresh tokens 7 days (rotated on every use).
JWT_SECRET=replace-with-a-32-byte-random-hex-secret-000000
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-random-hex-000000

# --- Image storage ---
# Dev stores uploads on the local filesystem under MEDIA_ROOT and serves them
# from MEDIA_URL_PREFIX; prod uploads to Cloudinary instead.
MEDIA_ROOT=uploads
MEDIA_URL_PREFIX=/uploads
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Payment gateways ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
EASYPAISA_MERCHANT_ID=

# --- Email (OTP + notification delivery; dev logs to console instead) ---
# Gmail setup: enable 2-Step Verification on the Google account, then create
# an App Password (myaccount.google.com/apppasswords) and paste the 16-char
# value below (no spaces). Regular Gmail passwords do NOT work over SMTP.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=
EMAIL_FROM=ArenaHub <you@gmail.com>
# Dev never opens SMTP (even with credentials) unless this is 1 — protects
# pytest runs from sending real email. Prod always sends.
EMAIL_SEND_IN_DEV=0

# --- Push notifications ---
# Delivered via the Expo Push service (exp.host) — the mobile app is a
# managed Expo project, so device tokens are Expo push tokens, not raw
# FCM/APNs tokens. No server key or Firebase project needed.
