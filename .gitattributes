# Normalize line endings to LF for all text files so Windows/macOS/Linux
# collaborators (and Linux CI/Docker later) don't fight over CRLF vs LF.
* text=auto eol=lf

# Explicit binaries — never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jks binary
*.keystore binary

# Lockfiles: keep LF, treat as generated in diffs.
uv.lock linguist-generated=true
package-lock.json linguist-generated=true
